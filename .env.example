# Copia este fichero como .env en la raíz del proyecto
# (usado por docker-compose.yml para variables compartidas)

GCS_BUCKET=finanzas-n26-data

# Para desarrollo local con ADC (Application Default Credentials):
# 1. Instala gcloud CLI: https://cloud.google.com/sdk/docs/install
# 2. Ejecuta: gcloud auth application-default login
# 3. El docker-compose monta ~/.config/gcloud automáticamente

# O usa un service account key (menos recomendado):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
